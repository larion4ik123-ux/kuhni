# ============================================================
# Платформа «Мебельный салон Интерьер» — кухни на заказ
# Пример переменных окружения. Скопируйте в .env и заполните.
# СЕКРЕТНЫЕ КЛЮЧИ ХРАНЯТЬ ТОЛЬКО НА СЕРВЕРЕ, не во frontend.
# ============================================================

# ---------- Приложение ----------
APP_ENV=development          # development | production
APP_HOST=127.0.0.1
APP_PORT=8000
APP_URL=http://127.0.0.1:8000   # публичный URL API (для вебхуков/ссылок)
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_PLEASE_GENERATE_WITH_openssl_rand_hex_32

# ---------- База данных ----------
# SQLite на этапе 1. Для PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./backend/data/kitchen.db

# ---------- Админпанель ----------
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_SESSION_MAX_AGE_HOURS=12

# ---------- Telegram (этап 1) ----------
TELEGRAM_BOT_TOKEN=PUT_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_BOT_URL=https://t.me/your_kitchen_bot?start=website_main
# Список chat_id менеджеров через запятую
MANAGER_CHAT_IDS=123456789,987654321
# URL вебхука (если используется вебхук вместо polling): https://your.domain/api/bot/webhook
TELEGRAM_WEBHOOK_URL=

# ---------- MAX (этап 2, заглушка) ----------
MAX_API_URL=
MAX_BOT_TOKEN=
MAX_BOT_URL=

# ---------- AI-генерация (polza.ai) ----------
# Базовый URL OpenAI-совместимого провайдера
AI_PROVIDER=mock            # mock | openai_compatible
AI_API_BASE_URL=https://polza.ai/api/v1
AI_API_KEY=PUT_POLZA_AI_API_KEY_HERE
# Модель для img2img (визуализация кухни по фото помещения)
AI_MODEL=bytedance/seedream-4.5
AI_QUALITY=basic            # basic (2K) | high (4K)
AI_TIMEOUT=600              # секунд
AI_RETRY_COUNT=2
AI_RESULTS_COUNT=1          # количество вариантов генерации
AI_MASTER_PROMPT=Создай реалистичную интерьерную фотографию кухни на заказ в существующем помещении клиента. Сохрани стены, окна, двери, пол, потолок, перспективу камеры, освещение и реальные габариты. Замени только зону кухни: старую мебель можно убрать, новую мебель поставить строго по выбранной форме. Если выбрана линейная кухня — мебель идёт вдоль одной стены; если угловая — вдоль двух смежных стен; если П-образная — по трём сторонам; если остров — добавь отдельный остров только при достаточном месте. Не добавляй людей, лишний декор, фантазийную архитектуру и элементы, которых нет в помещении. Стиль — дорогая, аккуратная, продающая фотография реальной кухни, а не 3D-рендер.

# ---------- Сайт / frontend (сборка) ----------
# Этап 1: GitHub Pages. Этап 2: собственный домен.
VITE_API_BASE_URL=https://api.example.com
# Для клиентской демонстрации кнопки подписаны как MAX, но можно временно
# указать Telegram-ссылку в VITE_MAX_BOT_URL, пока MAX-бот не подключён.
VITE_MAX_BOT_URL=https://t.me/your_kitchen_bot
VITE_TELEGRAM_BOT_URL=https://t.me/your_kitchen_bot

# ---------- Медиа / хранение ----------
MEDIA_DIR=./backend/media
MEDIA_BASE_URL=/media
MAX_UPLOAD_MB=20
# Срок хранения временных файлов генерации (дней)
GENERATION_RETENTION_DAYS=30

# ---------- Безопасность ----------
RATE_LIMIT_PER_MINUTE=60
CSRF_SECRET=CHANGE_ME_SEPARATE_RANDOM_SECRET
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
